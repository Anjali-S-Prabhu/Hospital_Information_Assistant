# Why it exists:
# The .dockerignore file prevents unnecessary or sensitive files from being copied
# into the Docker container. This keeps build times fast and prevents secrets leakage.

# Exclude local environment configs and secret files
.env
.env.example

# Exclude compiled Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude source control directories
.git
.gitignore

# Exclude local development environments and IDE settings
.vscode/
.idea/
.mypy_cache/
.pytest_cache/

# Exclude logs and database dumps
*.log
*.sqlite
*.db
